#!/usr/bin/env python3

import subprocess
import os
from typing import List, Tuple

speaker_icon = "󰕾"

CONFIG_DIR = os.environ.get("XDG_CONFIG_HOME", "~/.config")


def _get_sinks() -> List[Tuple[str, str]]:
    output = subprocess.run(
        ["pactl", "list", "sinks"], capture_output=True, text=True
    ).stdout.strip()

    sinks = []
    current = []
    for line in output.splitlines():
        if line.startswith("Sink #"):
            if current:
                sinks.append(current)
            current = []
        current.append(line.strip())
    if current:
        sinks.append(current)

    result = []
    for s in sinks:
        name = ""
        desc = ""
        for line in s:
            if "Name:" in line:
                name = line.split("Name:")[1].strip()
            if "Description:" in line:
                desc = line.split("Description:")[1].strip()
        if name:
            result.append((name, desc))

    return result


def _get_current_sink() -> str:
    return subprocess.run(
        ["pactl", "get-default-sink"], capture_output=True, text=True
    ).stdout.strip()


def show_output_menu() -> None:
    sinks = _get_sinks()
    current = _get_current_sink()

    options: List[Tuple[str, str]] = []

    for name, label in sinks:
        if name == current:
            label = f"[current] {label}"
        options.append((f"{speaker_icon} {label}", name))

    print("\0prompt\x1fAudio Output")
    print(f"\0message\x1fCurrent Output: {current}")

    for label, name in options:
        print(f"{label}{chr(0)}info\x1f{name}|{label}")


def set_output(name: str, label: str) -> None:
    subprocess.run(["pactl", "set-default-sink", name])
    subprocess.run(
        [
            "notify-send",
            "󰕾 Output Changed",
            f"Now using: {label}",
            "--expire-time=3000",
            "-u",
            "normal",
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


if __name__ == "__main__":
    if selection := os.environ.get("ROFI_INFO"):
        name, label = selection.split("|")
        set_output(name, label)
    else:
        show_output_menu()
