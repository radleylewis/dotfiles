#!/usr/bin/env python3

import subprocess
import os
from typing import List, Tuple

mic_icon = "󰍬"
yes_icon = ""
no_icon = ""

CONFIG_DIR = os.environ.get("XDG_CONFIG_HOME", "~/.config")


def _get_sources() -> List[str]:
    """Return all input devices (sources) with their human-readable names."""
    output = subprocess.run(
        ["pactl", "list", "sources"], capture_output=True, text=True
    ).stdout.strip()

    sources = []
    current = []
    for line in output.splitlines():
        if line.startswith("Source #"):
            if current:
                sources.append(current)
            current = []
        current.append(line.strip())
    if current:
        sources.append(current)

    result = []
    for s in sources:
        name = ""
        desc = ""
        for line in s:
            if "Name:" in line:
                name = line.split("Name:")[1].strip()
            if "Description:" in line:
                desc = line.split("Description:")[1].strip()
        if name:
            result.append((name, desc))

    return result


def _get_current_source() -> str:
    """Return the current default mic."""
    return subprocess.run(
        ["pactl", "get-default-source"], capture_output=True, text=True
    ).stdout.strip()


def show_microphone_menu() -> None:
    sources = _get_sources()
    current = _get_current_source()

    options: List[Tuple[str, str]] = []

    for name, label in sources:
        if name == current:
            label = f"[current] {label}"
        options.append((f"{mic_icon} {label}", name))

    print("\0prompt\x1fMicrophone")
    print(f"\0message\x1fCurrent Input: {current}")

    for label, name in options:
        print(f"{label}{chr(0)}info\x1f{name}|{label}")


def set_microphone(name: str, label) -> None:
    subprocess.run(["pactl", "set-default-source", name])
    subprocess.run(
        [
            "notify-send",
            "󰍬 Microphone Changed",
            f"Now using: {label}",
            "--expire-time=3000",
            "-u",
            "normal",
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


if __name__ == "__main__":
    if selection := os.environ.get("ROFI_INFO"):
        name, label = selection.split("|")
        set_microphone(name, label)
    else:
        show_microphone_menu()
